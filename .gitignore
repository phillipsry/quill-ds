# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# macOS AppleDouble metadata files (ExFAT drives)
._*

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated per-icon lazy modules and grouped tail (rebuilt by `npm run build:icons`)
/src/components/ui/icons/
/src/components/ui/icons.tail.mjs

*storybook.log
storybook-static

# a11y audit / verification artifacts
/*.png
/*-preview.html
.playwright-mcp/
public/axe.min.js

# agent tooling / scratch
.claude/
.superpowers/
docs/superpowers/plans/
src/components/ui/icon-names.generated.mjs
