{
  "name": "quill-ds",
  "version": "0.2.12",
  "private": true,
  "scripts": {
    "predev": "npm run build:icons",
    "dev": "next dev",
    "prebuild": "npm run build-storybook -- -o public/storybook",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prestorybook": "npm run build:icons",
    "storybook": "storybook dev -p 6006",
    "prebuild-storybook": "npm run build:tokens && npm run build:registry && npm run build:icons",
    "build-storybook": "storybook build",
    "build:tokens": "node scripts/build-tokens.mjs",
    "build:registry": "shadcn build",
    "build:icons": "node scripts/build-icons.mjs",
    "pretest:tokens": "npm run build:icons",
    "test:tokens": "node --test src/tokens/*.test.mjs scripts/*.test.mjs",
    "pretest-storybook": "npm run build:icons",
    "test-storybook": "vitest --project=storybook run",
    "pretest-storybook:watch": "npm run build:icons",
    "test-storybook:watch": "vitest --project=storybook",
    "pretest-storybook:coverage": "npm run build:icons",
    "test-storybook:coverage": "vitest --project=storybook run --coverage"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@material-symbols/svg-200": "^0.45.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "react-resizable-panels": "^4.12.2",
    "recharts": "^3.10.0",
    "shadcn": "^4.13.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.5.3",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/addon-mcp": "^0.7.0",
    "@storybook/addon-vitest": "^10.5.3",
    "@storybook/nextjs-vite": "^10.5.3",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-storybook": "^10.5.3",
    "playwright": "^1.61.1",
    "remark-gfm": "^4.0.1",
    "storybook": "^10.5.3",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
