{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "login",
  "title": "Login",
  "description": "A sign-in card with email and password fields, a remember-me checkbox, and primary and forgot-password actions.",
  "registryDependencies": [
    "card",
    "input",
    "label",
    "button",
    "checkbox"
  ],
  "files": [
    {
      "path": "registry/blocks/login.tsx",
      "content": "import {\n  Card,\n  CardHeader,\n  CardTitle,\n  CardDescription,\n  CardContent,\n  CardFooter,\n} from '@/components/ui/card'\nimport { Input } from '@/components/ui/input'\nimport { Label } from '@/components/ui/label'\nimport { Button } from '@/components/ui/button'\nimport { Checkbox } from '@/components/ui/checkbox'\n\nexport function Login() {\n  return (\n    <Card className=\"w-[380px]\">\n      <CardHeader>\n        <CardTitle>Sign in</CardTitle>\n        <CardDescription>Welcome back — enter your details to continue.</CardDescription>\n      </CardHeader>\n      <CardContent className=\"flex flex-col gap-4\">\n        <div className=\"flex flex-col gap-1.5\">\n          <Label htmlFor=\"login-email\">Email</Label>\n          <Input id=\"login-email\" type=\"email\" placeholder=\"you@example.com\" />\n        </div>\n        <div className=\"flex flex-col gap-1.5\">\n          <Label htmlFor=\"login-password\">Password</Label>\n          <Input id=\"login-password\" type=\"password\" placeholder=\"••••••••\" />\n        </div>\n        <div className=\"flex items-center gap-2\">\n          <Checkbox id=\"login-remember\" />\n          <Label htmlFor=\"login-remember\" className=\"font-normal\">\n            Remember me for 30 days\n          </Label>\n        </div>\n      </CardContent>\n      <CardFooter className=\"flex-col gap-2\">\n        <Button className=\"w-full\">Sign in</Button>\n        <Button variant=\"link\" className=\"w-full\">\n          Forgot your password?\n        </Button>\n      </CardFooter>\n    </Card>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/quill/login.tsx"
    }
  ],
  "type": "registry:block"
}