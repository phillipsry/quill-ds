{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "page-header",
  "title": "Page header",
  "description": "A page header with breadcrumb trail, title and description, and duplicate/new action buttons.",
  "registryDependencies": [
    "breadcrumb",
    "button",
    "https://www.quilldesignsystem.com/r/icon.json"
  ],
  "files": [
    {
      "path": "registry/blocks/page-header.tsx",
      "content": "import {\n  Breadcrumb,\n  BreadcrumbList,\n  BreadcrumbItem,\n  BreadcrumbLink,\n  BreadcrumbPage,\n  BreadcrumbSeparator,\n} from '@/components/ui/breadcrumb'\nimport { Button } from '@/components/ui/button'\nimport { Icon } from '@/components/ui/icon'\n\nexport function PageHeader() {\n  return (\n    <div className=\"flex flex-col gap-3 text-foreground\">\n      <Breadcrumb>\n        <BreadcrumbList>\n          <BreadcrumbItem>\n            <BreadcrumbLink href=\"#\">Projects</BreadcrumbLink>\n          </BreadcrumbItem>\n          <BreadcrumbSeparator />\n          <BreadcrumbItem>\n            <BreadcrumbLink href=\"#\">Acme site</BreadcrumbLink>\n          </BreadcrumbItem>\n          <BreadcrumbSeparator />\n          <BreadcrumbItem>\n            <BreadcrumbPage>Settings</BreadcrumbPage>\n          </BreadcrumbItem>\n        </BreadcrumbList>\n      </Breadcrumb>\n      <div className=\"flex items-end justify-between gap-4\">\n        <div className=\"flex flex-col gap-1\">\n          <h1 className=\"text-2xl font-medium\">Project settings</h1>\n          <p className=\"text-sm text-muted-foreground\">\n            Manage configuration, members, and integrations for this project.\n          </p>\n        </div>\n        <div className=\"flex gap-2\">\n          <Button variant=\"outline\">\n            <Icon name=\"content_copy\" size={16} /> Duplicate\n          </Button>\n          <Button>\n            <Icon name=\"add\" size={16} /> New\n          </Button>\n        </div>\n      </div>\n    </div>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/quill/page-header.tsx"
    }
  ],
  "type": "registry:block"
}