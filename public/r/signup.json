{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "signup",
  "title": "Sign up",
  "description": "An account creation card with name, email, and password fields plus a sign-in link.",
  "registryDependencies": [
    "card",
    "input",
    "label",
    "button"
  ],
  "files": [
    {
      "path": "registry/blocks/signup.tsx",
      "content": "import {\n  Card,\n  CardHeader,\n  CardTitle,\n  CardDescription,\n  CardContent,\n  CardFooter,\n} from '@/components/ui/card'\nimport { Input } from '@/components/ui/input'\nimport { Label } from '@/components/ui/label'\nimport { Button } from '@/components/ui/button'\n\nexport function Signup() {\n  return (\n    <Card className=\"w-[380px]\">\n      <CardHeader>\n        <CardTitle>Create your account</CardTitle>\n        <CardDescription>Start your 14-day free trial — no card required.</CardDescription>\n      </CardHeader>\n      <CardContent className=\"flex flex-col gap-4\">\n        <div className=\"flex flex-col gap-1.5\">\n          <Label htmlFor=\"su-name\">Full name</Label>\n          <Input id=\"su-name\" placeholder=\"Ada Lovelace\" />\n        </div>\n        <div className=\"flex flex-col gap-1.5\">\n          <Label htmlFor=\"su-email\">Work email</Label>\n          <Input id=\"su-email\" type=\"email\" placeholder=\"you@company.com\" />\n        </div>\n        <div className=\"flex flex-col gap-1.5\">\n          <Label htmlFor=\"su-password\">Password</Label>\n          <Input id=\"su-password\" type=\"password\" placeholder=\"At least 8 characters\" />\n        </div>\n      </CardContent>\n      <CardFooter className=\"flex-col gap-2\">\n        <Button className=\"w-full\">Create account</Button>\n        <p className=\"text-center text-xs text-muted-foreground\">\n          Already have an account?{' '}\n          <a href=\"#\" className=\"text-primary underline underline-offset-4\">\n            Sign in\n          </a>\n        </p>\n      </CardFooter>\n    </Card>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/quill/signup.tsx"
    }
  ],
  "type": "registry:block"
}